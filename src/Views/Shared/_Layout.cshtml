<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Worksheet Generator</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <style>
        :root { --primary: #4f46e5; --primary-dark: #4338ca; }
        body { background: #f5f6fa; font-family: 'Segoe UI', system-ui, sans-serif; }
        .navbar-brand { font-weight: 700; letter-spacing: -0.02em; }
        .navbar { background: linear-gradient(135deg, #1e1b4b 0%, #312e81 100%) !important; }
        .card { border: none; border-radius: 12px; box-shadow: 0 2px 12px rgba(0,0,0,.07); }
        .card-header { border-radius: 12px 12px 0 0 !important; }
        .btn-primary { background: var(--primary); border-color: var(--primary); }
        .btn-primary:hover { background: var(--primary-dark); border-color: var(--primary-dark); }
        .badge-mc   { background: #dbeafe; color: #1d4ed8; }
        .badge-tf   { background: #dcfce7; color: #15803d; }
        .badge-fb   { background: #fef9c3; color: #a16207; }
        .badge-sa   { background: #fce7f3; color: #be185d; }
        .badge-wp   { background: #ffedd5; color: #c2410c; }
        .badge-type { font-size: .7rem; font-weight: 600; padding: .25em .55em; border-radius: 6px; text-transform: uppercase; letter-spacing: .05em; }
        .question-card { border-left: 4px solid #e5e7eb; border-radius: 0 8px 8px 0; }
        .question-card:hover { border-left-color: var(--primary); }
        .step-circle { width: 36px; height: 36px; border-radius: 50%; background: var(--primary); color: #fff;
                       display: flex; align-items: center; justify-content: center; font-weight: 700; flex-shrink: 0; }
        @@media print { .no-print { display: none !important; } }
        .min-width-0 { min-width: 0; }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark no-print mb-1">
        <div class="container">
            <a class="navbar-brand text-white" href="/">
                <i class="bi bi-journal-richtext me-2"></i>Worksheet Generator
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#nav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="nav">
                <ul class="navbar-nav ms-auto gap-1">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Index">
                            <i class="bi bi-house me-1"></i>Home
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Profile" asp-action="Index">
                            <i class="bi bi-people me-1"></i>Profiles
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Material" asp-action="Index">
                            <i class="bi bi-book me-1"></i>Library
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Template" asp-action="Index">
                            <i class="bi bi-layout-text-sidebar-reverse me-1"></i>Templates
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Worksheet" asp-action="History">
                            <i class="bi bi-clock-history me-1"></i>History
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-white-50" asp-controller="Admin" asp-action="Migrate" title="Migrate SQLite → PostgreSQL">
                            <i class="bi bi-database-up"></i>
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <main class="container my-4" style="min-height: 600px;">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show no-print d-flex align-items-center gap-2" role="alert">
                <i class="bi bi-check-circle-fill"></i>
                <span>@TempData["Success"]</span>
                <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show no-print d-flex align-items-center gap-2" role="alert">
                <i class="bi bi-exclamation-triangle-fill"></i>
                <span>@TempData["Error"]</span>
                <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
            </div>
        }
        @RenderBody()
    </main>

    <footer class="bg-dark text-white text-center py-3 mt-5 no-print">
        <small><i class="bi bi-stars me-1"></i>Worksheet Generator &mdash; Powered by TechWayFit &copy; @DateTime.Now.Year</small>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
