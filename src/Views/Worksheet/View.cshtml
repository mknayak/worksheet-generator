@model WorksheetViewModel
@{
    ViewData["Title"] = Model.Worksheet.Title;
    var ws = Model.Worksheet;
    var student = Model.Student;

    string TypeLabel(string t) => t switch {
        "multiple_choice" => "Multiple Choice",
        "true_false"      => "True / False",
        "fill_blank"      => "Fill in the Blank",
        "short_answer"    => "Short Answer",
        "word_problem"    => "Word Problem",
        _                 => t
    };
    string TypeBadgeClass(string t) => t switch {
        "multiple_choice" => "badge-mc",
        "true_false"      => "badge-tf",
        "fill_blank"      => "badge-fb",
        "short_answer"    => "badge-sa",
        "word_problem"    => "badge-wp",
        _                 => "bg-secondary text-white"
    };
}

<!-- Action Bar -->
<div class="mb-4 no-print">
    <div class="text-muted small mb-2">
        Generated @ws.GeneratedAt.ToString("MMM d, yyyy 'at' h:mm tt") from <em>@ws.SourceFileName</em>
    </div>
    <!-- Mobile: stacked buttons -->
    <div class="d-flex flex-column gap-2 d-sm-none">
        <a asp-action="PrintWorksheet" asp-route-id="@ws.Id" class="btn btn-primary" target="_blank">
            <i class="bi bi-file-earmark-arrow-down me-1"></i>Download Worksheet PDF
        </a>
        <a asp-action="PrintAnswers" asp-route-id="@ws.Id" class="btn btn-success" target="_blank">
            <i class="bi bi-key me-1"></i>Download Answer Key
        </a>
        <div class="d-flex gap-2">
            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary flex-grow-1">
                <i class="bi bi-arrow-left me-1"></i>Home
            </a>
            <a asp-action="DownloadJson" asp-route-id="@ws.Id" class="btn btn-outline-dark flex-grow-1">
                <i class="bi bi-filetype-json me-1"></i>JSON
            </a>
            <form asp-action="Delete" method="post" class="flex-grow-1"
                  onsubmit="return confirm('Delete this worksheet permanently?')">
                <input type="hidden" name="id" value="@ws.Id" />
                <button class="btn btn-outline-danger w-100"><i class="bi bi-trash me-1"></i>Delete</button>
            </form>
        </div>
    </div>
    <!-- Desktop: inline buttons -->
    <div class="d-none d-sm-flex flex-wrap gap-2 align-items-center">
        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left me-1"></i>Home
        </a>
        <a asp-action="PrintWorksheet" asp-route-id="@ws.Id" class="btn btn-primary btn-sm" target="_blank">
            <i class="bi bi-file-earmark-arrow-down me-1"></i>Download Worksheet PDF
        </a>
        <a asp-action="PrintAnswers" asp-route-id="@ws.Id" class="btn btn-success btn-sm" target="_blank">
            <i class="bi bi-key me-1"></i>Download Answer Key
        </a>
        <a asp-action="DownloadJson" asp-route-id="@ws.Id" class="btn btn-outline-dark btn-sm">
            <i class="bi bi-filetype-json me-1"></i>JSON
        </a>
        <form asp-action="Delete" method="post" class="mb-0"
              onsubmit="return confirm('Delete this worksheet permanently?')">
            <input type="hidden" name="id" value="@ws.Id" />
            <button class="btn btn-outline-danger btn-sm"><i class="bi bi-trash me-1"></i>Delete</button>
        </form>
    </div>
</div>

<!-- Worksheet Preview Card -->
<div class="card mb-4">
    <!-- Header -->
    <div class="card-header py-4" style="background: linear-gradient(135deg,#1e1b4b,#4f46e5); color:#fff;">
        <div class="row align-items-center">
            <div class="col">
                <div class="text-uppercase small opacity-75 mb-1">@ws.Subject</div>
                <h3 class="mb-1 fw-bold">@ws.Title</h3>
                <div class="opacity-90">@ws.Topic</div>
            </div>
            <div class="col-auto text-end">
                <div class="badge bg-white text-dark fs-6 px-3 py-2 mb-1">
                    @ws.TotalPoints pts
                </div>
                <div class="small opacity-75">@ws.Questions.Count questions &bull; ~@ws.EstimatedMinutes min</div>
            </div>
        </div>
    </div>

    <!-- Student Info Bar -->
    @if (student != null)
    {
        <div class="bg-light border-bottom px-4 py-2">
            <div class="row small text-muted">
                <div class="col-auto"><i class="bi bi-person me-1"></i><strong>@student.Name</strong></div>
                @if (!string.IsNullOrEmpty(student.ClassName))
                { <div class="col-auto"><i class="bi bi-layers me-1"></i>@student.ClassName</div> }
                @if (!string.IsNullOrEmpty(student.Grade))
                { <div class="col-auto"><i class="bi bi-mortarboard me-1"></i>@student.Grade</div> }
                @if (!string.IsNullOrEmpty(student.School))
                { <div class="col-auto"><i class="bi bi-building me-1"></i>@student.School</div> }
                @if (!string.IsNullOrEmpty(student.TeacherName))
                { <div class="col-auto"><i class="bi bi-person-badge me-1"></i>@student.TeacherName</div> }
            </div>
        </div>
    }

    <!-- Instructions -->
    <div class="card-body px-4 pt-3 pb-2">
        <div class="alert alert-info py-2 mb-0">
            <i class="bi bi-info-circle me-2"></i>@ws.Instructions
        </div>
    </div>

    <!-- Questions -->
    <div class="card-body px-4 pt-2">
        @for (int i = 0; i < ws.Questions.Count; i++)
        {
            var q = ws.Questions[i];
            <div class="question-card bg-white border rounded p-3 mb-3">
                <div class="d-flex justify-content-between align-items-start mb-2">
                    <div class="d-flex align-items-start gap-2 flex-grow-1">
                        <span class="fw-bold text-muted" style="min-width:24px;">@(i+1).</span>
                        <div class="flex-grow-1">
                            <span class="@TypeBadgeClass(q.Type) badge-type badge me-2">@TypeLabel(q.Type)</span>
                            <span class="fw-semibold">@q.Text</span>
                        </div>
                    </div>
                    <span class="badge bg-light text-dark border ms-2 text-nowrap">@q.Points pt@(q.Points == 1 ? "" : "s")</span>
                </div>

                @if (q.Type == "word_problem")
                {
                    <!-- Working space preview -->
                    <div class="ms-4 mt-2">
                        <div class="small text-muted mb-1 fw-semibold">Working:</div>
                        @for (int l = 0; l < 5; l++)
                        {
                            <div class="border-bottom border-secondary mb-3" style="height:28px;"></div>
                        }
                        <div class="d-flex align-items-center gap-2 mt-1">
                            <span class="small fw-semibold">Answer:</span>
                            <div class="border-bottom border-dark flex-grow-1" style="height:28px;"></div>
                        </div>
                    </div>
                }
                else if (q.Options.Any())
                {
                    <div class="ms-4 mt-2">
                        @foreach (var opt in q.Options)
                        {
                            <div class="d-flex align-items-center gap-2 mb-1">
                                <div class="rounded-circle border d-flex align-items-center justify-content-center flex-shrink-0"
                                     style="width:20px;height:20px;"></div>
                                <span class="small">@opt</span>
                            </div>
                        }
                    </div>
                }
                else if (q.Type == "fill_blank")
                {
                    <div class="ms-4 mt-2 border-bottom border-secondary" style="width:200px;height:28px;"></div>
                }
                else if (q.Type == "short_answer")
                {
                    <div class="ms-4 mt-2">
                        @for (int l = 0; l < 3; l++)
                        {
                            <div class="border-bottom border-secondary mb-3" style="height:28px;"></div>
                        }
                    </div>
                }

                <!-- Answer / worked solution (preview) -->
                @if (q.Type == "word_problem")
                {
                    <div class="ms-4 mt-3 p-3 rounded" style="background:#fff7ed;border-left:3px solid #f97316;">
                        <div class="small text-warning fw-semibold mb-1">
                            <i class="bi bi-calculator me-1"></i>Worked Solution:
                        </div>
                        @foreach (var line in q.Answer.Split('\n'))
                        {
                            <div class="small text-dark">@line</div>
                        }
                    </div>
                }
                else
                {
                    <div class="ms-4 mt-2 p-2 rounded" style="background:#f0fdf4;border-left:3px solid #22c55e;">
                        <small class="text-success fw-semibold"><i class="bi bi-check-circle me-1"></i>Answer: </small>
                        <small class="text-dark">@q.Answer</small>
                    </div>
                }
            </div>
        }
    </div>
</div>

<!-- Summary footer -->
<div class="row g-3 mb-4 no-print">
    <div class="col-sm-4">
        <div class="card text-center py-3">
            <div class="h4 mb-0 text-primary fw-bold">@ws.Questions.Count</div>
            <div class="small text-muted">Total Questions</div>
        </div>
    </div>
    <div class="col-sm-4">
        <div class="card text-center py-3">
            <div class="h4 mb-0 text-success fw-bold">@ws.TotalPoints</div>
            <div class="small text-muted">Total Points</div>
        </div>
    </div>
    <div class="col-sm-4">
        <div class="card text-center py-3">
            <div class="h4 mb-0 text-warning fw-bold">~@ws.EstimatedMinutes</div>
            <div class="small text-muted">Minutes</div>
        </div>
    </div>
</div>
