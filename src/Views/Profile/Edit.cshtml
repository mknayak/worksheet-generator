@model StudentProfile
@{
    ViewData["Title"] = "Edit Profile";
}

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="card">
            <div class="card-header py-3 bg-white">
                <h5 class="mb-0 fw-bold"><i class="bi bi-pencil me-2 text-primary"></i>Edit Profile — @Model.Name</h5>
            </div>
            <div class="card-body p-4">
                <form asp-action="Edit" method="post">
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="CreatedAt" />
                    <div class="row g-3">
                        <div class="col-12">
                            <label asp-for="Name" class="form-label fw-semibold">Student Name *</label>
                            <input asp-for="Name" class="form-control" required />
                        </div>
                        <div class="col-sm-6">
                            <label asp-for="ClassName" class="form-label fw-semibold">Class / Section</label>
                            <input asp-for="ClassName" class="form-control" />
                        </div>
                        <div class="col-sm-6">
                            <label asp-for="Grade" class="form-label fw-semibold">Grade / Year</label>
                            <input asp-for="Grade" class="form-control" />
                        </div>
                        <div class="col-12">
                            <label asp-for="School" class="form-label fw-semibold">School / Institution</label>
                            <input asp-for="School" class="form-control" />
                        </div>
                        <div class="col-12">
                            <label asp-for="TeacherName" class="form-label fw-semibold">Teacher Name</label>
                            <input asp-for="TeacherName" class="form-control" />
                        </div>
                    </div>
                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-primary px-4">
                            <i class="bi bi-check-lg me-1"></i>Update Profile
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
