@model List<StudentProfile>
@{
    ViewData["Title"] = "Student Profiles";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-0 fw-bold"><i class="bi bi-people me-2 text-primary"></i>Student Profiles</h4>
        <small class="text-muted">Reusable profiles pre-fill student info on every worksheet</small>
    </div>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i>New Profile
    </a>
</div>

@if (!Model.Any())
{
    <div class="card text-center py-5">
        <div class="card-body">
            <i class="bi bi-person-plus text-muted" style="font-size:3rem;"></i>
            <h5 class="mt-3">No profiles yet</h5>
            <p class="text-muted">Create a student profile to automatically fill in name, class, and school on worksheets.</p>
            <a asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-lg me-1"></i>Create First Profile
            </a>
        </div>
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var p in Model)
        {
            <div class="col-md-6 col-lg-4">
                <div class="card h-100">
                    <div class="card-body">
                        <div class="d-flex align-items-center mb-3">
                            <div class="rounded-circle d-flex align-items-center justify-content-center me-3 flex-shrink-0"
                                 style="width:48px;height:48px;background:linear-gradient(135deg,#4f46e5,#7c3aed);color:#fff;font-size:1.3rem;font-weight:700;">
                                @(string.IsNullOrEmpty(p.Name) ? "?" : p.Name[0].ToString().ToUpper())
                            </div>
                            <div>
                                <h6 class="mb-0 fw-bold">@p.Name</h6>
                                <small class="text-muted">@p.ClassName &bull; @p.Grade</small>
                            </div>
                        </div>
                        <div class="small text-muted">
                            @if (!string.IsNullOrEmpty(p.School))
                            {
                                <div><i class="bi bi-building me-1"></i>@p.School</div>
                            }
                            @if (!string.IsNullOrEmpty(p.TeacherName))
                            {
                                <div><i class="bi bi-person-badge me-1"></i>@p.TeacherName</div>
                            }
                            <div><i class="bi bi-calendar3 me-1"></i>Added @p.CreatedAt.ToString("MMM d, yyyy")</div>
                        </div>
                    </div>
                    <div class="card-footer bg-white border-0 d-flex gap-2">
                        <a asp-action="Edit" asp-route-id="@p.Id" class="btn btn-sm btn-outline-primary flex-grow-1">
                            <i class="bi bi-pencil me-1"></i>Edit
                        </a>
                        <form asp-action="Delete" method="post" class="flex-grow-1"
                              onsubmit="return confirm('Delete profile for @p.Name?')">
                            <input type="hidden" name="id" value="@p.Id" />
                            <button type="submit" class="btn btn-sm btn-outline-danger w-100">
                                <i class="bi bi-trash me-1"></i>Delete
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
}
