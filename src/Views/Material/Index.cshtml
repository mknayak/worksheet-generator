@model MaterialLibraryViewModel
@{
    ViewData["Title"] = "Material Library";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h4 class="mb-0 fw-bold"><i class="bi bi-book me-2 text-primary"></i>Material Library</h4>
        <small class="text-muted">Saved PDF sessions — re-generate worksheets any time without re-uploading</small>
    </div>
    <a asp-controller="Home" asp-action="Index" class="btn btn-primary btn-sm">
        <i class="bi bi-cloud-upload me-1"></i>Upload New PDF
    </a>
</div>

<!-- Filters -->
<div class="card mb-4">
    <div class="card-body py-2">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-sm-4">
                <label class="form-label small fw-semibold mb-1">Subject</label>
                <select name="subject" class="form-select form-select-sm">
                    <option value="">All subjects</option>
                    @foreach (var s in Model.Subjects)
                    {
                        <option value="@s" selected="@(Model.FilterSubject == s)">@s</option>
                    }
                </select>
            </div>
            <div class="col-sm-4">
                <label class="form-label small fw-semibold mb-1">Class</label>
                <select name="className" class="form-select form-select-sm">
                    <option value="">All classes</option>
                    @foreach (var c in Model.Classes)
                    {
                        <option value="@c" selected="@(Model.FilterClass == c)">@c</option>
                    }
                </select>
            </div>
            <div class="col-sm-4 d-flex gap-2">
                <button type="submit" class="btn btn-primary btn-sm flex-grow-1">
                    <i class="bi bi-funnel me-1"></i>Filter
                </button>
                @if (!string.IsNullOrEmpty(Model.FilterSubject) || !string.IsNullOrEmpty(Model.FilterClass))
                {
                    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Clear</a>
                }
            </div>
        </form>
    </div>
</div>

@if (!Model.Materials.Any())
{
    <div class="card text-center py-5">
        <div class="card-body">
            <i class="bi bi-book text-muted" style="font-size:3rem;"></i>
            <h5 class="mt-3">
                @if (!string.IsNullOrEmpty(Model.FilterSubject) || !string.IsNullOrEmpty(Model.FilterClass))
                { <span>No materials match this filter</span> }
                else
                { <span>Library is empty</span> }
            </h5>
            <p class="text-muted">Upload a PDF and it will be saved here automatically.</p>
            <a asp-controller="Home" asp-action="Index" class="btn btn-primary">
                <i class="bi bi-cloud-upload me-1"></i>Upload First PDF
            </a>
        </div>
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var m in Model.Materials)
        {
            <div class="col-md-6 col-lg-4">
                <div class="card h-100">
                    <div class="card-body">
                        <!-- Subject + Class badges -->
                        <div class="d-flex gap-1 mb-2 flex-wrap">
                            @if (!string.IsNullOrEmpty(m.Subject))
                            {
                                <span class="badge" style="background:#ede9fe;color:#4f46e5;">@m.Subject</span>
                            }
                            @if (!string.IsNullOrEmpty(m.ClassName))
                            {
                                <span class="badge" style="background:#dcfce7;color:#15803d;">@m.ClassName</span>
                            }
                        </div>

                        <h6 class="fw-bold mb-1">@m.Title</h6>
                        <div class="small text-muted mb-2">
                            <i class="bi bi-file-earmark-pdf me-1 text-danger"></i>@m.OriginalFileName
                        </div>
                        <div class="small text-muted">
                            <i class="bi bi-calendar3 me-1"></i>@m.UploadedAt.ToString("MMM d, yyyy")
                            &nbsp;&bull;&nbsp;
                            <i class="bi bi-text-left me-1"></i>@(m.ExtractedText.Length.ToString("N0")) chars
                        </div>
                    </div>
                    <div class="card-footer bg-white border-0 d-flex gap-2">
                        <a asp-action="Detail" asp-route-id="@m.Id" class="btn btn-sm btn-primary flex-grow-1">
                            <i class="bi bi-eye me-1"></i>View & Generate
                        </a>
                        <form asp-action="Delete" method="post"
                              onsubmit="return confirm('Delete this material? Existing worksheets will not be deleted.')">
                            <input type="hidden" name="id" value="@m.Id" />
                            <button type="submit" class="btn btn-sm btn-outline-danger">
                                <i class="bi bi-trash"></i>
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
}
