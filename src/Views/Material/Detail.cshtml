@model MaterialDetailViewModel
@{
    ViewData["Title"] = Model.Material.Title;
    var m = Model.Material;
}

<!-- Breadcrumb -->
<nav aria-label="breadcrumb" class="mb-3 no-print">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-action="Index">Library</a></li>
        <li class="breadcrumb-item active">@m.Title</li>
    </ol>
</nav>

<div class="row g-4">

    <!-- Left: Material info + generate form -->
    <div class="col-lg-4">
        <div class="card mb-3">
            <div class="card-header py-3 d-flex justify-content-between align-items-center"
                 style="background:linear-gradient(135deg,#4f46e5,#7c3aed);color:#fff;">
                <h6 class="mb-0 fw-bold"><i class="bi bi-book me-2"></i>Material</h6>
                <a asp-action="Edit" asp-route-id="@m.Id"
                   class="btn btn-sm btn-light text-primary fw-semibold">
                    <i class="bi bi-pencil me-1"></i>Edit
                </a>
            </div>
            <div class="card-body">
                <h5 class="fw-bold mb-1">@m.Title</h5>
                <div class="d-flex gap-1 mb-3 flex-wrap">
                    @if (!string.IsNullOrEmpty(m.Subject))
                    {
                        <span class="badge" style="background:#ede9fe;color:#4f46e5;">@m.Subject</span>
                    }
                    @if (!string.IsNullOrEmpty(m.ClassName))
                    {
                        <span class="badge" style="background:#dcfce7;color:#15803d;">@m.ClassName</span>
                    }
                </div>
                <div class="small text-muted">
                    <div class="mb-1"><i class="bi bi-file-earmark-pdf me-1 text-danger"></i>@m.OriginalFileName</div>
                    <div class="mb-1"><i class="bi bi-calendar3 me-1"></i>Uploaded @m.UploadedAt.ToString("MMM d, yyyy 'at' h:mm tt")</div>
                    <div><i class="bi bi-text-paragraph me-1"></i>@(m.ExtractedText.Length.ToString("N0")) characters extracted</div>
                </div>
            </div>
        </div>

        <!-- Generate new worksheet card -->
        <div class="card border-primary">
            <div class="card-header bg-white fw-semibold py-3 text-primary">
                <i class="bi bi-magic me-2"></i>Generate New Worksheet
            </div>
            <div class="card-body">
                <form asp-action="GenerateWorksheet" method="post" id="generateForm">
                    <input type="hidden" name="materialId" value="@m.Id" />

                    <!-- Student Profile -->
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Student Profile <span class="text-muted fw-normal">(optional)</span></label>
                        @if (!Model.Profiles.Any())
                        {
                            <div class="text-muted small">
                                <a asp-controller="Profile" asp-action="Create">Create a profile</a> to pre-fill student info.
                            </div>
                        }
                        else
                        {
                            <select name="profileId" class="form-select form-select-sm">
                                <option value="">— No profile —</option>
                                @foreach (var p in Model.Profiles)
                                {
                                    <option value="@p.Id">@p.Name (@p.ClassName)</option>
                                }
                            </select>
                        }
                    </div>

                    <!-- Worksheet Template -->
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Template <span class="text-muted fw-normal">(optional)</span></label>
                        @if (!Model.Templates.Any())
                        {
                            <div class="text-muted small">
                                <a asp-controller="Template" asp-action="Create">Create a template</a> to control question types.
                            </div>
                        }
                        else
                        {
                            <select name="templateId" class="form-select form-select-sm">
                                <option value="">— Default mix —</option>
                                @foreach (var t in Model.Templates)
                                {
                                    <option value="@t.Id">@t.Name (@t.TotalQuestions Qs)</option>
                                }
                            </select>
                        }
                    </div>

                    <!-- Sample Questions -->
                    <div class="mb-3">
                        <div class="d-flex justify-content-between align-items-center">
                            <label class="form-label small fw-semibold mb-0">
                                Sample Questions <span class="text-muted fw-normal">(optional)</span>
                            </label>
                            <button type="button" class="btn btn-link btn-sm py-0 text-muted"
                                    data-bs-toggle="collapse" data-bs-target="#sampleQuestionsCollapse">
                                Add samples
                            </button>
                        </div>
                        <div class="collapse" id="sampleQuestionsCollapse">
                            <textarea name="sampleQuestions" class="form-control form-control-sm mt-2"
                                      rows="5" placeholder="Paste a few example questions here. The AI will generate new questions in the same style, format, and difficulty level.&#10;&#10;E.g.:&#10;1. What is the capital of France?&#10;2. True or False: Water boils at 100°C.&#10;3. The _____ is the powerhouse of the cell."></textarea>
                            <div class="form-text">One question per line. The AI will match style and difficulty, not copy them.</div>
                        </div>
                    </div>

                    <button type="submit" class="btn btn-primary w-100" id="genBtn">
                        <i class="bi bi-magic me-1"></i>Generate Worksheet
                    </button>
                    <p class="text-muted small text-center mt-2 mb-0">
                        <i class="bi bi-clock me-1"></i>~10–30 seconds
                    </p>

                    <div id="genLoading" class="text-center mt-3 d-none">
                        <div class="spinner-border spinner-border-sm text-primary"></div>
                        <span class="small text-muted ms-2">Generating…</span>
                    </div>
                </form>
            </div>
        </div>

        <!-- Extracted text preview -->
        <div class="card mt-3">
            <div class="card-header bg-white py-2 d-flex justify-content-between align-items-center">
                <span class="small fw-semibold"><i class="bi bi-file-text me-1"></i>Extracted Text Preview</span>
                <button class="btn btn-link btn-sm py-0 text-muted" type="button"
                        data-bs-toggle="collapse" data-bs-target="#textPreview">
                    Show / Hide
                </button>
            </div>
            <div class="collapse" id="textPreview">
                <div class="card-body p-3">
                    <pre class="small text-muted mb-0" style="white-space:pre-wrap;max-height:300px;overflow-y:auto;">@(m.ExtractedText.Length > 2000 ? m.ExtractedText[..2000] + "\n\n[… truncated for preview]" : m.ExtractedText)</pre>
                </div>
            </div>
        </div>
    </div>

    <!-- Right: Worksheets generated from this material -->
    <div class="col-lg-8">
        <div class="card">
            <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                <span class="fw-semibold"><i class="bi bi-journal-text me-2 text-primary"></i>Worksheets generated from this material</span>
                <span class="badge bg-light text-dark border">@Model.Worksheets.Count</span>
            </div>

            @if (!Model.Worksheets.Any())
            {
                <div class="card-body text-center text-muted py-5">
                    <i class="bi bi-journal-x d-block mb-2" style="font-size:2rem;"></i>
                    No worksheets yet — use the form above to generate the first one.
                </div>
            }
            else
            {
                <!-- Mobile cards (xs–sm) -->
                <div class="d-md-none p-3 d-flex flex-column gap-3">
                    @foreach (var ws in Model.Worksheets)
                    {
                        <div class="border rounded p-3">
                            <div class="fw-semibold mb-1">@ws.Title</div>
                            <div class="text-muted small mb-1">@ws.Topic</div>
                            <div class="d-flex flex-wrap gap-2 align-items-center mb-3">
                                <span class="badge bg-light text-dark border">@ws.QuestionCount Qs &bull; @ws.TotalPoints pts</span>
                                @if (!string.IsNullOrEmpty(ws.StudentName) && ws.StudentName != "—")
                                {
                                    <span class="badge bg-light text-primary border"><i class="bi bi-person me-1"></i>@ws.StudentName</span>
                                }
                                <span class="text-muted small ms-auto">@ws.GeneratedAt.ToString("MMM d")</span>
                            </div>
                            <div class="d-flex gap-2 flex-wrap">
                                <a asp-controller="Worksheet" asp-action="View" asp-route-id="@ws.Id"
                                   class="btn btn-outline-primary btn-sm flex-grow-1">
                                    <i class="bi bi-eye me-1"></i>View
                                </a>
                                <a asp-controller="Worksheet" asp-action="PrintWorksheet" asp-route-id="@ws.Id"
                                   class="btn btn-outline-primary btn-sm flex-grow-1" target="_blank">
                                    <i class="bi bi-file-earmark-arrow-down me-1"></i>Worksheet
                                </a>
                                <a asp-controller="Worksheet" asp-action="PrintAnswers" asp-route-id="@ws.Id"
                                   class="btn btn-outline-success btn-sm flex-grow-1" target="_blank">
                                    <i class="bi bi-key me-1"></i>Answers
                                </a>
                            </div>
                        </div>
                    }
                </div>

                <!-- Desktop table (md+) -->
                <div class="table-responsive d-none d-md-block">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Worksheet</th>
                                <th>Student</th>
                                <th class="text-center">Qs</th>
                                <th class="text-center">Pts</th>
                                <th>Generated</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var ws in Model.Worksheets)
                            {
                                <tr>
                                    <td>
                                        <div class="fw-semibold">@ws.Title</div>
                                        <small class="text-muted">@ws.Topic</small>
                                    </td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(ws.StudentName) && ws.StudentName != "—")
                                        {
                                            <span class="badge bg-light text-dark border">
                                                <i class="bi bi-person me-1"></i>@ws.StudentName
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="text-muted small">—</span>
                                        }
                                    </td>
                                    <td class="text-center">@ws.QuestionCount</td>
                                    <td class="text-center">@ws.TotalPoints</td>
                                    <td>
                                        <div class="small">@ws.GeneratedAt.ToString("MMM d, yyyy")</div>
                                        <div class="small text-muted">@ws.GeneratedAt.ToString("h:mm tt")</div>
                                    </td>
                                    <td class="text-end">
                                        <div class="btn-group btn-group-sm">
                                            <a asp-controller="Worksheet" asp-action="View"
                                               asp-route-id="@ws.Id" class="btn btn-outline-primary" title="View">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                            <a asp-controller="Worksheet" asp-action="PrintWorksheet"
                                               asp-route-id="@ws.Id" class="btn btn-outline-primary" target="_blank" title="Worksheet PDF">
                                                <i class="bi bi-file-earmark-arrow-down"></i>
                                            </a>
                                            <a asp-controller="Worksheet" asp-action="PrintAnswers"
                                               asp-route-id="@ws.Id" class="btn btn-outline-success" target="_blank" title="Answer Key">
                                                <i class="bi bi-key"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
<script>
    document.getElementById('generateForm').addEventListener('submit', () => {
        document.getElementById('genBtn').disabled = true;
        document.getElementById('genLoading').classList.remove('d-none');
    });
</script>
}
